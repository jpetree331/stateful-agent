# Postgres (Railway). Required for conversation history.
# Get full URL from Railway: Postgres service -> Connect -> Postgres URL
# Format: postgresql://postgres:PASSWORD@HOST:PORT/railway
# Example: postgresql://postgres:xxx@shinkansen.proxy.rlwy.net:30278/railway
DATABASE_URL=

# Optional: AI context window for history (default: 200000). Must leave room for system prompt + tools.
# Kimi-K2.5: 262k total.
# CONTEXT_WINDOW_TOKENS=200000

# Optional: Timezone for agent's time awareness (default: America/New_York).
# The agent will know the current date/time in this timezone.
# AGENT_TIMEZONE=America/New_York

# LLM API Keys (set at least one)
OPENAI_API_KEY=sk-...
# Optional: Backup provider. When primary hits rate limit (429), agent retries with backup.
# Each provider can have its own base URL and model (e.g. synthetic.new primary, Kimi Code backup).
# OPENAI_API_KEY_BACKUP=sk-...
# OPENAI_BASE_URL_BACKUP=https://api.kimi.com/coding/v1
# OPENAI_MODEL_NAME_BACKUP=moonshotai/Kimi-K2.5-TEE
ANTHROPIC_API_KEY=sk-ant-...

# Custom LLM endpoint (e.g. synthetic.new, Chutes AI). Leave empty for default OpenAI/Anthropic.
# Include /v1 at the end for OpenAI-compatible APIs.
OPENAI_BASE_URL=
# Example: https://api.synthetic.new/openai/v1
# Example: https://your-username-your-chute.chutes.ai/v1

# Model name when using custom base URL (e.g. gpt-oss-120b, kimi-k-2.5)
OPENAI_MODEL_NAME=

# ── Vision (screenshot analysis) ──────────────────────────────────────────────
# Override any of these to use a completely separate provider for vision/images.
# All three fall back to the main chat settings if not set.
#
# Example: use Kimi Code for chat, but OpenAI gpt-4o-mini for vision:
#   VISION_MODEL_NAME=gpt-4o-mini
#   VISION_BASE_URL=https://api.openai.com/v1
#   VISION_API_KEY=sk-...your-openai-key...
#
# Example: use Kimi Code for chat, Kimi K2.5 multimodal for vision (same key):
#   VISION_MODEL_NAME=kimi-k2.5
#   VISION_BASE_URL=https://api.moonshot.ai/v1
#   (VISION_API_KEY not needed — reuses OPENAI_API_KEY)
#
# VISION_MODEL_NAME=        # defaults to OPENAI_MODEL_NAME
# VISION_BASE_URL=          # defaults to OPENAI_BASE_URL
# VISION_API_KEY=           # defaults to OPENAI_API_KEY
#
# Image quality tuning (lower = faster, smaller payload):
# VISION_MAX_WIDTH=1024     # max pixels wide sent to vision model
# VISION_MAX_HEIGHT=768
# VISION_JPEG_QUALITY=75    # 1-95, 75 is visually identical for analysis
#
# Qwen/DeepSeek on Chutes: reasoning is on by default. Set to false to disable for vision.
# VISION_ENABLE_THINKING=false

# ── TTS ───────────────────────────────────────────────────────────────────────
# Provider: TTS_PROVIDER=vibevoice | kitten | kokoro
#
# VibeVoice (local, 1.5B, p254_collage). Best tool-call reliability. Requires E:\git\VibeVoice.
# TTS_PROVIDER=vibevoice
# VIBEVOICE_ROOT=E:\git\VibeVoice
# VIBEVOICE_REFERENCE_VOICE=E:\git\VibeVoice\demo\voices_1_5b\p254_collage.mp3
# VIBEVOICE_DEVICE=cuda
# VIBEVOICE_TIMEOUT=480
#
# KittenTTS (local, CPU-friendly, 80M):
# KITTENTTS_MODEL=KittenML/kitten-tts-mini-0.8
# KITTENTTS_DEFAULT_VOICE=Leo                    # Bella, Jasper, Luna, Bruno, Rosie, Hugo, Kiki, Leo
# KITTENTTS_PLAY_AFTER_GENERATE=true
#
# Kokoro (Chutes AI, GPU-hosted, 82M). Uses Chutes-hosted chutes-kokoro by default.
# TTS_PROVIDER=kokoro
# KOKORO_TTS_BASE_URL=https://chutes-kokoro.chutes.ai       # Default; override for custom chute
# KOKORO_TTS_API_KEY=cpk_...                                # Chutes API key (or reuse OPENAI_API_KEY)
# KOKORO_TTS_DEFAULT_VOICE=af_heart                         # af_heart, af_bella, af_sarah, am_adam, am_michael, etc.
# KOKORO_TTS_SPEED=1                                        # Speech speed (default 1)

# Hindsight: Deep memory (retain, recall, reflect). Run Hindsight server via Docker first.
# See README or run: docker run -p 8888:8888 -p 9999:9999 -e HINDSIGHT_API_LLM_* ghcr.io/vectorize-io/hindsight:latest
HINDSIGHT_BASE_URL=http://localhost:8888
HINDSIGHT_BANK_ID=openclaw-log
# HINDSIGHT_ENABLED=true
# HINDSIGHT_USER_ID=user:229027909430411264

# Default user identity for local/chat usage (optional).
# Used when user_id is not provided in API calls.
# DEFAULT_USER_ID=229027909430411264
# DEFAULT_CHANNEL_TYPE=local  # "discord", "telegram", or "local"

# Hindsight server LLM (set when running Docker). Use Chutes gpt-oss-120b:
# HINDSIGHT_API_LLM_PROVIDER=openai
# HINDSIGHT_API_LLM_BASE_URL=https://your-chute.chutes.ai/v1
# HINDSIGHT_API_LLM_MODEL=openai/gpt-oss-120b-TEE
# HINDSIGHT_API_LLM_API_KEY=your-chutes-api-key

# ── Knowledge Bank (RAG) ───────────────────────────────────────────────────────
# Local Postgres database for knowledge files + vector search. Separate from Railway.
# Setup: python -m scripts.setup_knowledge_db  (creates DB + enables pgvector)
KNOWLEDGE_DATABASE_URL=postgresql://postgres:password@localhost:5432/stateful-agent-kb
# Embedding model via Chutes (OpenAI-compatible). Qwen3-Embedding-8B outputs 4096-dim vectors.
KNOWLEDGE_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
# Fall back to main OpenAI/Chutes settings if not set
# EMBEDDING_BASE_URL=     # defaults to OPENAI_BASE_URL
# EMBEDDING_API_KEY=     # defaults to OPENAI_API_KEY

# Discord bot integration
# DISCORD_BOT_TOKEN — get from https://discord.com/developers/applications → Bot → Token
# DISCORD_CHANNEL_ID — right-click any channel (or DM) in Discord with Developer Mode on → Copy ID
#   For DMs: open your DM with the bot, then use the channel ID from the URL or Developer Mode
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# Telegram bot integration
# TELEGRAM_BOT_TOKEN — get from @BotFather on Telegram
# TELEGRAM_CHAT_ID — your personal chat ID with the bot
#   To find it: message @userinfobot on Telegram, or check the getUpdates API response
# TELEGRAM_WEBHOOK_URL — when set, Telegram pushes updates (no polling). Use with ngrok:
#   https://your-ngrok.ngrok-free.app/api/telegram-webhook
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_WEBHOOK_URL=

# Heartbeat: autonomous background thinking cycles
# HEARTBEAT_ENABLED=true          # Set to false to disable all heartbeat cycles
# HEARTBEAT_INTERVAL_MINUTES=60   # How often the scheduler fires (default: 60 min)

# Heartbeat prompts — dual-mode system (Wonder = exploration, Work = projects)
# Mode-specific paths take priority; HEARTBEAT_PROMPT_PATH is the shared fallback.
# HEARTBEAT_WONDER_PROMPT_PATH=C:\path\to\HEARTBEAT_WONDER.txt
# HEARTBEAT_WORK_PROMPT_PATH=C:\path\to\HEARTBEAT_WORK.txt
# HEARTBEAT_PROMPT_PATH=C:\path\to\HEARTBEAT.txt   # shared fallback (single-file mode)

# Work window: agent runs Work heartbeats during this pre-online window (24h hours)
# All other active hours use Wonder. Defaults: Work = 7 AM – 10 AM.
# HEARTBEAT_WORK_START_HOUR=7
# HEARTBEAT_WORK_END_HOUR=10

# Dashboard password (optional). When set, ngrok/public dashboard requires HTTP Basic Auth.
# Username can be anything; password must match. Leave empty for no auth (local dev).
# DASHBOARD_PASSWORD=your-secret-password

# LangSmith: Dashboard for tracing agent runs, LLM calls, tool usage.
# Get API key at https://smith.langchain.com/settings
# Set to true to enable; traces appear at https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
# Optional: custom project name (default: "default")
# LANGCHAIN_PROJECT=stateful-agent
